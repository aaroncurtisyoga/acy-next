generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

model Order {
  id          String  @id @default(uuid())
  createdAt   DateTime @default(now())
  stripeId    String  @unique
  totalAmount String?
  eventId     String?
  event       Event?   @relation(fields: [eventId], references: [id])
  buyerId     String
  buyer       User    @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  type        OrderType

  @@index([buyerId])
}

enum OrderType {
  EVENT
  PRIVATE_SESSION
}

model Event {
  id                     String    @id @default(uuid())
  isActive               Boolean   @default(true)
  createdAt              DateTime  @default(now())
  description            String?
  endDateTime            DateTime  @default(now())
  externalRegistrationUrl String?
  imageUrl               String?
  isFree                 Boolean   @default(false)
  isFeatured             Boolean   @default(false)
  isHostedExternally     Boolean
  maxAttendees           Int?
  price                  String?
  startDateTime          DateTime  @default(now())
  title                  String
  categoryId             String
  category               Category  @relation(fields: [categoryId], references: [id])
  locationId             String
  location               Location  @relation(fields: [locationId], references: [id])
  order                  Order[]
  attendees              EventUser[]

  // External sync fields
  sourceType      String?   // 'MOMENCE'
  sourceId        String?   // External booking ID
  externalUrl     String?   // Direct booking link
  lastSynced      DateTime?
  isExternal      Boolean   @default(false)

  // Google Calendar sync fields
  googleEventId   String?   // Google Calendar event ID
  googleEventLink String?   // Direct link to Google Calendar event

  @@unique([sourceType, sourceId]) // Prevent duplicate synced events
  @@index([googleEventId])
  @@index([categoryId])
  @@index([locationId])
  @@index([startDateTime])
  @@index([isActive, startDateTime])
}

model User {
  id        String @id @default(uuid())
  clerkId   String @unique
  email     String @unique
  firstName String
  lastName  String
  photo     String
  orders    Order[]
  events    EventUser[]
}

model EventUser {
  user   User   @relation(fields: [userId], references: [id])
  userId String // relation scalar field to User

  event  Event  @relation(fields: [eventId], references: [id])
  eventId String // relation scalar field to Event

  @@id([userId, eventId])
}

model Location {
  id               String    @id @default(uuid())
  formattedAddress String?
  lat              Float?
  lng              Float?
  name             String?
  placeId          String? @unique
  events           Event[]
}

model Category {
  id   String @id @default(uuid())
  name String @unique
  events Event[]
}

model Newsletter {
  id                String           @id @default(uuid())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  subject           String
  previewText       String?
  content           String // TipTap-generated HTML body
  status            NewsletterStatus @default(DRAFT)
  scheduledAt       DateTime?
  sentAt            DateTime?
  resendBroadcastId String?

  // Which auto-sections get appended below the message at send time
  includeUpcoming     Boolean @default(true)
  includeClasses      Boolean @default(true)
  includeDescriptions Boolean @default(false)

  // Unique-recipient counters, incremented by the Resend webhook
  deliveredCount  Int @default(0)
  openedCount     Int @default(0)
  clickedCount    Int @default(0)
  bouncedCount    Int @default(0)
  complainedCount Int @default(0)

  // Active-subscriber count captured at send time — the denominator that
  // makes the counters comparable across sends as the list grows.
  recipientCount Int?

  // Exact rendered HTML handed to Resend at send/schedule time. The event
  // sections change daily, so without this the sent view would rebuild them
  // from today's data and silently misrepresent what went out.
  sentHtml String?

  emailEvents NewsletterEmailEvent[]

  @@index([status, scheduledAt])
  @@index([resendBroadcastId])
}

// Dedup ledger for Resend webhook events: one row per (newsletter, recipient
// email id, event type) so repeat opens/clicks by the same person count once.
// Click events additionally get one row per clicked URL (link != ""), which
// powers the "Top clicked links" view; the link-less row remains the ledger
// entry that drives the unique-recipient clickedCount.
model NewsletterEmailEvent {
  id           String     @id @default(uuid())
  newsletterId String
  emailId      String
  type         String
  link         String     @default("")
  // Recipient address, recorded for bounce/complaint rows only — a bounce on
  // a small personal list is usually a typo'd address the admin can fix, but
  // only if the admin can see which address it was.
  recipient    String?
  createdAt    DateTime   @default(now())
  newsletter   Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade)

  @@unique([newsletterId, emailId, type, link])
  @@index([newsletterId, type])
}

enum NewsletterStatus {
  DRAFT
  SCHEDULED
  SENT
}

// Reserved for a future reading-list feature. Not wired to any route, query,
// or server action yet — safe to build on or drop.
model Book {
  id                 String    @id @default(uuid())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  title              String
  author             String
  description        String?
  coverImageUrl      String?
  openLibraryKey     String?   @unique
  isCurrentlyReading Boolean   @default(false)
}
